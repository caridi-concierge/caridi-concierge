# Contact form email delivery (Resend). Required for /api/contact to send mail.
RESEND_API_KEY=

# Cloudflare Turnstile bot verification (optional).
# When TURNSTILE_SECRET_KEY is set, /api/contact enforces verification.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY is exposed to the client to render the widget.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Service prices (USD). Read once in src/lib/constants/pricing.ts as PRICES.
PRICE_CONSULT=
PRICE_BOTOX=
PRICE_DERMAL_FILLER=
PRICE_BIOSTIMULATORY_FILLER=
PRICE_CHEMICAL_PEELS=
